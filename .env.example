# Database - SQLite (local file, no server) - default
DATABASE_TYPE=sqlite
# Database file: backend/data/helmet_violations.db

# MongoDB (alternative)
MONGODB_URI=mongodb://localhost:27017/helmet_violations

# Twilio (SMS)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# WhatsApp (Twilio WhatsApp API)
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Payment Gateway (for fine payment link)
PAYMENT_BASE_URL=https://your-payment-gateway.com/pay

# Flask
FLASK_SECRET_KEY=your-secret-key
FLASK_DEBUG=1
